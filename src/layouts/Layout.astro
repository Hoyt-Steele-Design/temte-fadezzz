---
import '../styles/global.css'

export interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="description"
      content="Temte's Fades & Shaves — barber in Eden Prairie, MN"
    />
    <meta property="og:title" content="Temte's Fades & Shaves" />
    <meta property="og:description" content="Temte's Fades & Shaves — barber in Eden Prairie, MN" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Temte's Fades & Shaves" />
    <meta name="twitter:description" content="Temte's Fades & Shaves — barber in Eden Prairie, MN" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="mx-auto max-w-screen pt-16">
    <slot />
  </body>
</html>

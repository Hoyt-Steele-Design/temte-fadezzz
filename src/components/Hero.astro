---
import { getImage } from 'astro:assets'
import heroMobileImg from '../images/hero-mobile.jpg'
import heroDesktopImg from '../images/hero-desktop.jpeg'
import mobileSvg from '../assets/your-fade-logo-mobile.svg?raw'
import desktopSvg from '../assets/your-fade-logo-desktop.svg?raw'

const mobileImage = await getImage({ src: heroMobileImg })
const desktopImage = await getImage({ src: heroDesktopImg })
---

<section
  id="home"
  class="hero relative overflow-hidden bg-cover bg-center flex items-center justify-center"
  style={`--bg-mobile: url(${mobileImage.src}); --bg-desktop: url(${desktopImage.src})`}
>
  <div
    class="pointer-events-none absolute inset-0 bg-linear-to-b from-transparent to-black/10"
  >
  </div>
  <div class="relative z-10 flex flex-col items-center gap-10 w-full lg:px-8 lg:gap-12 lg:max-w-5xl">
    <div class="hero-fade-center w-full">
      <div class="block lg:hidden w-full max-w-sm mx-auto" aria-label="Your Fade × Your Story">
        <Fragment set:html={mobileSvg} />
      </div>
      <div class="hidden lg:block w-full mx-auto" aria-label="Your Fade × Your Story">
        <Fragment set:html={desktopSvg} />
      </div>
    </div>
    <div class="flex flex-col items-center gap-6 w-full px-8 lg:flex-row lg:gap-3 lg:justify-center lg:px-0">
      <a
        href="https://booksy.com/en-us/936262_temtes-fades-shaves_barber-shop_24080_eden-prairie#ba_s=seo"
        target="_blank"
        rel="noopener noreferrer"
        class="btn hero-cta hero-cta-gold lg:text-btn-lg w-full px-9 py-4.5 lg:w-1/3 bg-gold/80 backdrop-blur-sm border border-gold/50 text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.15)] [text-shadow:0_1px_8px_rgba(0,0,0,0.7)]"
      >
        Book Appointment
      </a>
      <a
        href="#portfolio"
        class="btn hero-cta hero-cta-white lg:text-btn-lg w-full px-9 py-4.5 lg:w-1/3 bg-white/20 backdrop-blur-sm border border-white/40 text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.15)] [text-shadow:0_1px_8px_rgba(0,0,0,0.7)]"
      >
        View Portfolio
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background-image: var(--bg-mobile);
    height: calc(var(--lock-height, calc(100svh - 4rem)) + env(safe-area-inset-bottom, 0px));
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: -3px;
    background-image: var(--bg-mobile);
    background-size: cover;
    background-position: center;
    filter: brightness(0.9) contrast(1.06) saturate(1.02) hue-rotate(5deg);
    transform: scale(1.01);
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(6, 10, 16, 0.1), rgba(6, 10, 16, 0.1)),
      rgba(36, 58, 88, 0.1);
    pointer-events: none;
  }

  @media (min-width: 1024px) {
    .hero {
      background-image: var(--bg-desktop);
    }

    .hero::before {
      content: none;
    }

    .hero::after {
      content: none;
    }
  }

  .hero-fade-center svg {
    overflow: visible;
  }

  .hero-cta {
    transition:
      transform 340ms ease,
      border-color 340ms ease,
      background-color 340ms ease,
      box-shadow 460ms ease;
  }

  .hero-cta:hover,
  .hero-cta:focus-visible {
    transform: translateY(-1px);
  }

  .hero-cta-gold:hover,
  .hero-cta-gold:focus-visible {
    background-color: rgba(196, 168, 78, 0.9);
    border-color: rgba(196, 168, 78, 0.75);
    box-shadow:
      0 0 22px rgba(196, 168, 78, 0.42),
      0 8px 18px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .hero-cta-white:hover,
  .hero-cta-white:focus-visible {
    background-color: rgba(255, 255, 255, 0.28);
    border-color: rgba(255, 255, 255, 0.68);
    box-shadow:
      0 0 22px rgba(255, 255, 255, 0.28),
      0 8px 18px rgba(0, 0, 0, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.24);
  }

  @media (min-width: 1024px) {
    .hero-cta {
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        box-shadow 180ms ease;
    }
  }
</style>

<script is:inline>
  (function () {
    var hero = document.getElementById('home');
    var siteHeader = document.querySelector('header');

    function lockHero() {
      if (!hero) return;
      if (window.innerWidth >= 1024) {
        hero.style.removeProperty('--lock-height');
        return;
      }
      var isPortrait = window.innerHeight > window.innerWidth;
      if (isPortrait) {
        var headerHeight = siteHeader ? siteHeader.offsetHeight : 64;
        hero.style.setProperty('--lock-height', (window.innerHeight - headerHeight) + 'px');
      } else {
        hero.style.removeProperty('--lock-height');
      }
    }

    lockHero();

    var lastWidth = window.innerWidth;
    window.addEventListener('resize', function () {
      if (window.innerWidth !== lastWidth) {
        lastWidth = window.innerWidth;
        lockHero();
      }
    });

    window.addEventListener('orientationchange', function () {
      setTimeout(lockHero, 150);
    });
  })();
</script>

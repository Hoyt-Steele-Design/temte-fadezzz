---
import { getImage } from 'astro:assets'
import heroMobileImg from '../images/hero-mobile.jpg'
import heroDesktopImg from '../images/hero-desktop.jpeg'

const mobileImage = await getImage({ src: heroMobileImg })
const desktopImage = await getImage({ src: heroDesktopImg })
---

<section
  id="home"
  class="hero relative flex min-h-screen flex-col items-center justify-start bg-cover bg-center pt-32 lg:justify-center lg:pt-0"
  style={`--bg-mobile: url(${mobileImage.src}); --bg-desktop: url(${desktopImage.src})`}
>
  <div
    class="pointer-events-none absolute inset-0 bg-linear-to-b from-transparent to-black/10"
  >
  </div>
  <div class="relative z-10 flex w-full flex-col items-center gap-28 px-8 lg:gap-12">
    <div class="hero-diagonal flex flex-col items-center gap-2 lg:flex-row lg:items-stretch lg:gap-0">
      <div class="hero-fade-left flex items-center justify-center lg:justify-start">
        <h1
          class="font-garamond hero-title text-2xl leading-none font-bold whitespace-nowrap text-white"
        >
          Your Fade
        </h1>
      </div>
      <div class="hero-fade-center flex items-center justify-center px-4 py-1 lg:py-0">
        <div class="hero-x-container">
          <div class="hero-slash-line hero-slash-line--pos"></div>
          <div class="hero-slash-line hero-slash-line--neg"></div>
        </div>
      </div>
      <div class="hero-fade-right flex items-center justify-center lg:justify-end">
        <h1
          class="font-garamond hero-accent text-gold text-2xl leading-none font-bold whitespace-nowrap"
        >
          Your Story
        </h1>
      </div>
    </div>

    <div
      class="flex w-full flex-col items-center justify-center gap-6 lg:flex-row lg:gap-3"
    >
      <a
        href="https://booksy.com/en-us/936262_temtes-fades-shaves_barber-shop_24080_eden-prairie#ba_s=seo"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-gold lg:text-btn-lg w-full px-9 py-4.5 lg:w-1/3"
      >
        Book Appointment
      </a>
      <a
        href="#portfolio"
        class="btn btn-ghost-white lg:text-btn-lg w-full px-9 py-4.5 lg:w-1/3"
      >
        View Portfolio
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background-image: var(--bg-mobile);
  }

  @media (min-width: 1024px) {
    .hero {
      background-image: var(--bg-desktop);
    }
  }

  .hero-title {
    font-size: clamp(3.25rem, 15vw, 4rem);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.8);
    -webkit-text-stroke: 0.3px rgba(255, 255, 255, 0.3);
  }

  .hero-accent {
    font-size: clamp(3.25rem, 15vw, 4rem);
    text-shadow:
      0 2px 16px rgba(0, 0, 0, 0.8),
      0 0 8px rgba(196, 168, 78, 0.7);
    -webkit-text-stroke: 0.6px rgba(196, 168, 78, 0.6);
  }

  @media (min-width: 1024px) {
    .hero-diagonal {
      height: 5rem;
    }
  }

  .hero-x-container {
    position: relative;
    width: 160px;
    height: 70px;
  }

  .hero-slash-line {
    position: absolute;
    width: 1px;
    height: 100%;
    left: 50%;
    top: 0;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(196, 168, 78, 0.9) 20%,
      rgba(255, 255, 255, 0.95) 45%,
      rgba(255, 255, 255, 0.95) 55%,
      rgba(196, 168, 78, 0.9) 80%,
      transparent
    );
    box-shadow: 0 0 8px 2px rgba(196, 168, 78, 0.6);
  }

  .hero-slash-line--pos {
    transform: translateX(-50%) rotate(30deg);
  }

  .hero-slash-line--neg {
    transform: translateX(-50%) rotate(-30deg);
  }

  @media (min-width: 1024px) {
    .hero-x-container {
      width: 14px;
      height: 120%;
    }
  }

  /* Entrance animations */
  @keyframes heroFadeLeft {
    from {
      opacity: 0;
      transform: translateX(-16px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes heroFadeCenter {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes heroFadeRight {
    from {
      opacity: 0;
      transform: translateX(16px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .hero-fade-left {
    animation: heroFadeLeft 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }

  .hero-fade-center {
    animation: heroFadeCenter 0.9s ease 0.5s both;
  }

  .hero-fade-right {
    animation: heroFadeRight 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.7s both;
  }
</style>

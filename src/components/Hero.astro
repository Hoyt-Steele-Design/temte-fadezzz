---
const {
  heroBgImg,
  title = "Your Fade, Your Story",
  primaryLink,
  secondaryLink
} = Astro.props;
---

<section
  class="hero flex flex-col font-weight justify-center items-center p-8 min-h-screen gap-6"
  style={`background-image: url(${heroBgImg.src}); background-size: cover; background-position: center;`}
>
  <h1 class="text-5xl font-bold leading-tight text-white">
    {title.split(",")[0]}, <br />{title.split(",")[1]}
  </h1>

  <div class="flex flex-col items-center gap-3 text-white">
    {primaryLink && (
      <a
        href={primaryLink.href}
        class="button font-inter text-sm font-semibold tracking-widest uppercase px-6 py-3 bg-gold text-black rounded-sm"
      >
        {primaryLink.label}
      </a>
    )}

    {secondaryLink && (
      <a
        href={secondaryLink.href}
        class="button font-inter text-sm font-semibold tracking-widest uppercase px-6 py-3 border-2 border-current rounded-sm"
      >
        {secondaryLink.label}
      </a>
    )}
  </div>
</section>

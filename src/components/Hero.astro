---
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
import mobileSvg from '../assets/your-fade-logo-mobile.svg?raw'
import desktopSvg from '../assets/your-fade-logo-desktop.svg?raw'

const reader = createReader(process.cwd(), keystaticConfig)
const hero = await reader.singletons.hero.read()
const bgMobile = hero?.backgroundImageMobile ? `/images/hero/${hero.backgroundImageMobile}` : ''
const bgDesktop = hero?.backgroundImageDesktop ? `/images/hero/${hero.backgroundImageDesktop}` : ''
---

<section
  id="home"
  class="hero relative overflow-hidden bg-cover bg-center flex items-center justify-center pb-16 lg:pb-0"
  style={`--bg-mobile: url(${bgMobile}); --bg-desktop: url(${bgDesktop})`}
>
  <div
    class="pointer-events-none absolute inset-0 bg-linear-to-b from-transparent to-black/10"
  >
  </div>
  <div class="relative z-10 flex flex-col items-center gap-4 w-full lg:px-8 lg:gap-12 lg:max-w-5xl">
    <div class="hero-fade-center w-full">
      <div class="block lg:hidden w-full max-w-sm mx-auto" aria-label="Your Fade × Your Story">
        <Fragment set:html={mobileSvg} />
      </div>
      <div class="hidden lg:block w-full mx-auto" aria-label="Your Fade × Your Story">
        <Fragment set:html={desktopSvg} />
      </div>
    </div>
    <div class="flex flex-col items-center gap-6 w-full px-8 lg:flex-row lg:gap-3 lg:justify-center lg:px-0">
      <a
        href="https://booksy.com/en-us/936262_temtes-fades-shaves_barber-shop_24080_eden-prairie#ba_s=seo"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-glass-gold lg:text-btn-lg w-full px-9 py-4.5 lg:w-1/3"
      >
        Book Appointment
      </a>
      <a
        href="#portfolio"
        class="btn btn-glass-white lg:text-btn-lg w-full px-9 py-4.5 lg:w-1/3"
      >
        View Portfolio
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    --hero-viewport-height: 100vh;

    background-image: var(--bg-mobile);
    height: var(--hero-viewport-height);
  }

  @supports (height: 100svh) {
    .hero {
      --hero-viewport-height: 100svh;
    }
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: -3px;
    background-image: var(--bg-mobile);
    background-size: cover;
    background-position: center;
    filter: brightness(0.9) contrast(1.06) saturate(1.02) hue-rotate(5deg);
    transform: scale(1.01);
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(6, 10, 16, 0.1), rgba(6, 10, 16, 0.1)),
      rgba(36, 58, 88, 0.1);
    pointer-events: none;
  }

  @media (min-width: 1024px) {
    .hero {
      background-image: var(--bg-desktop);
    }

    .hero::before {
      content: none;
    }

    .hero::after {
      content: none;
    }
  }

  .hero-fade-center svg {
    overflow: visible;
  }
</style>

<script>
  const hero = document.getElementById('home') as HTMLElement | null
  const mobileViewport = window.matchMedia('(max-width: 1023px)')

  let lockedViewportWidth = 0
  let lockedViewportOrientation = ''
  let lockedHeroHeight = 0
  let resizeTimer: number | undefined

  function getViewportSize() {
    const viewport = window.visualViewport

    return {
      width: Math.round(viewport?.width ?? window.innerWidth),
      height: Math.round(viewport?.height ?? window.innerHeight),
      orientation:
        window.screen.orientation?.type ??
        (window.innerWidth > window.innerHeight ? 'landscape' : 'portrait'),
    }
  }

  function setLockedHeroHeight(force = false) {
    if (!hero) return

    if (!mobileViewport.matches) {
      hero.style.removeProperty('--hero-viewport-height')
      lockedViewportWidth = 0
      lockedViewportOrientation = ''
      lockedHeroHeight = 0
      return
    }

    const viewport = getViewportSize()
    const viewportWidthChanged =
      Math.abs(viewport.width - lockedViewportWidth) > 8
    const viewportOrientationChanged =
      viewport.orientation !== lockedViewportOrientation

    if (
      force ||
      viewportWidthChanged ||
      viewportOrientationChanged ||
      lockedHeroHeight === 0
    ) {
      lockedViewportWidth = viewport.width
      lockedViewportOrientation = viewport.orientation
      lockedHeroHeight = viewport.height
    } else {
      lockedHeroHeight = Math.min(lockedHeroHeight, viewport.height)
    }

    hero.style.setProperty('--hero-viewport-height', `${lockedHeroHeight}px`)
  }

  function scheduleLockedHeroHeight(force = false) {
    window.clearTimeout(resizeTimer)
    setLockedHeroHeight(force)
    resizeTimer = window.setTimeout(() => setLockedHeroHeight(force), 150)
  }

  scheduleLockedHeroHeight(true)

  window.addEventListener('pageshow', () => scheduleLockedHeroHeight(true))
  window.addEventListener('resize', () => scheduleLockedHeroHeight())
  window.addEventListener('orientationchange', () => {
    lockedViewportWidth = 0
    lockedViewportOrientation = ''
    window.setTimeout(() => scheduleLockedHeroHeight(true), 300)
  })

  window.visualViewport?.addEventListener('resize', () => scheduleLockedHeroHeight())
  mobileViewport.addEventListener('change', () => scheduleLockedHeroHeight(true))
</script>

---
import { getImage } from 'astro:assets'
import heroMobileImg from '../images/hero-mobile.jpg'
import heroDesktopImg from '../images/hero-desktop.jpeg'

const mobileImage = await getImage({ src: heroMobileImg })
const desktopImage = await getImage({ src: heroDesktopImg })
---

<div
  class="hero flex min-h-screen flex-col items-center justify-center gap-8 bg-cover bg-center mb-8 lg:mb-16"
  style={`--bg-mobile: url(${mobileImage.src}); --bg-desktop: url(${desktopImage.src})`}
>
  <div class="flex flex-col items-center justify-center gap-8 w-full px-8">
  <div class="flex flex-col items-center text-center">
    <h1 class="font-garamond hero-title text-white leading-none font-semibold">Your Fade</h1>
    <div class="w-12 lg:w-24 h-px bg-gold mt-4 lg:mt-6 mb-2" style="box-shadow: 0 0 4px 1px rgba(196,168,78,0.35)"></div>
    <h1 class="font-garamond hero-accent text-gold leading-none font-semibold">Your Story</h1>
  </div>

  <div class="flex flex-col lg:flex-row items-center gap-3 lg:gap-6">
    <a
      href="https://booksy.com/en-us/936262_temtes-fades-shaves_barber-shop_24080_eden-prairie#ba_s=seo"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-gold w-64 px-6 py-3 lg:w-auto lg:px-9 lg:py-[1.125rem] lg:text-btn-lg"
    >
      Book Appointment
    </a>
    <a
      href="#portfolio"
      class="btn btn-ghost-white w-64 px-6 py-3 lg:w-auto lg:px-9 lg:py-[1.125rem] lg:text-btn-lg"
    >
      View Portfolio
    </a>
  </div>
  </div>
</div>

<style>
  .hero {
    background-image: var(--bg-mobile);
  }

  @media (min-width: 1024px) {
    .hero {
      background-image: var(--bg-desktop);
    }
  }

  .hero-title {
    font-size: clamp(2.75rem, 5vw, 4.5rem);
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
    -webkit-text-stroke: 0.3px rgba(255,255,255,0.3);
  }

  .hero-accent {
    font-size: clamp(3.75rem, 6.5vw, 6rem);
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
    -webkit-text-stroke: 0.3px rgba(196,168,78,0.3);
  }
</style>

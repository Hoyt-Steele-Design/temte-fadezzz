---
---

<header class="fixed top-0 left-0 right-0 z-50 max-w-screen-lg mx-auto flex items-center justify-center p-4 bg-white">
  <button id="menu-open" aria-label="Open menu" aria-expanded="false" aria-controls="nav-drawer" class="absolute left-4 flex flex-col gap-1.5 p-2 bg-white/40 backdrop-blur-sm rounded">
    <span class="block w-6 h-0.5 bg-current"></span>
    <span class="block w-6 h-0.5 bg-current"></span>
    <span class="block w-6 h-0.5 bg-current"></span>
  </button>

  <a href="/" class="brand">
    <span class="text-2xl font-bold tracking-tight">TEMTE's <span class="text-sm font-light">Fades & Shaves</span></span>
  </a>
</header>

<dialog
  id="nav-drawer"
  class="fixed inset-y-0 right-0 m-0 h-screen max-h-screen w-[70%] max-w-sm bg-black text-white p-8
         translate-x-full transition-transform duration-300 ease-in-out
         open:translate-x-0 backdrop:bg-black/50"
>
  <button id="menu-close" aria-label="Close menu" class="ml-auto flex p-2 text-2xl leading-none">✕</button>

  <nav class="mt-8" aria-label="Site navigation">
    <ul class="flex flex-col gap-4 text-base font-semibold tracking-widest uppercase">
      <li><a href="#" onclick="document.getElementById('nav-drawer').close()">Home</a></li>
      <li><a href="#about-me" onclick="document.getElementById('nav-drawer').close()">About</a></li>
      <li><a href="#services" onclick="document.getElementById('nav-drawer').close()">Services</a></li>
      <li><a href="#portfolio" onclick="document.getElementById('nav-drawer').close()">Portfolio</a></li>
      <li><a href="#location" onclick="document.getElementById('nav-drawer').close()">Location</a></li>
    </ul>
  </nav>

  <a
    href="https://booksy.com/en-us/936262_temtes-fades-shaves_barber-shop_24080_eden-prairie#ba_s=seo"
    target="_blank"
    rel="noopener noreferrer"
    class="btn btn-gold mt-6 inline-block px-6 py-3 whitespace-nowrap"
  >
    Book Appointment
  </a>

  <div class="absolute bottom-8 left-8 right-8 flex flex-col items-center gap-4">
    <div class="flex gap-5">
      <!-- Instagram -->
      <a href="#" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <!-- Facebook -->
      <a href="#" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
      <!-- TikTok -->
      <a href="#" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
        </svg>
      </a>
      <!-- X / Twitter -->
      <a href="#" target="_blank" rel="noopener noreferrer" aria-label="X">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </div>
    <p class="text-xs font-light">&copy; 2026 TEMTE's Fades & Shaves</p>
  </div>
</dialog>

<script>
  const drawer = document.getElementById('nav-drawer') as HTMLDialogElement;
  const openBtn = document.getElementById('menu-open')!;
  openBtn.addEventListener('click', () => {
    drawer.showModal();
    openBtn.setAttribute('aria-expanded', 'true');
  });
  const closeDrawer = () => {
    drawer.close();
    openBtn.setAttribute('aria-expanded', 'false');
  };
  document.getElementById('menu-close')!.addEventListener('click', closeDrawer);

  drawer.addEventListener('click', (e) => {
    if (e.target === drawer) closeDrawer();
  });

</script>

---
import SocialIcons from './SocialIcons.astro'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
const reader = createReader(process.cwd(), keystaticConfig)
const settings = await reader.singletons.settings.read()
const bookingUrl = settings?.bookingUrl ?? ''
---

<header
  class="fixed grid grid-cols-3 items-center top-0 right-0 left-0 z-50 bg-white p-4 lg:flex lg:items-end lg:justify-between"
>
  <button
    id="menu-open"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-drawer"
    class="flex flex-col items-center gap-2 justify-self-start lg:hidden"
  >
    <span class="block h-0.5 w-6 bg-current"></span>
    <span class="block h-0.5 w-6 bg-current"></span>
    <span class="block h-0.5 w-6 bg-current"></span>
  </button>

  <a
    href="/"
    class="col-start-2 justify-self-center text-nowrap lg:justify-self-auto"
  >
    <span class="text-3xl font-bold tracking-tight lg:text-3xl">TEMTE's </span>
    <span class="font-light text-nowrap lg:text-xl">Fades & Shaves</span
    >
  </a>
  <nav class="hidden lg:block" aria-label="Site navigation">
    <ul class="flex h-full flex-row items-end gap-8 text-xl font-medium xl:gap-12">
      <li><a href="#home" class="nav-link">Home</a></li>
      <li><a href="#about-me" class="nav-link">About Me</a></li>
      <li><a href="#portfolio" class="nav-link">Portfolio</a></li>
      <li><a href="#services" class="nav-link">Services</a></li>
      <li><a href="#location" class="nav-link">Location</a></li>
    </ul>
  </nav>

  <a
    href={bookingUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="btn btn-gold hidden px-5 py-2.5 text-sm lg:flex lg:items-center whitespace-nowrap"
  >
    Book Now
  </a>

  <dialog
    id="nav-drawer"
    class="m-0 bg-black p-8 text-white backdrop:bg-black/50"
  >
    <div class="flex flex-wrap items-center justify-between gap-3">
      <a href="/" class="min-w-0 flex-1 text-white text-nowrap overflow-hidden">
        <span class="text-lg font-bold tracking-tight">TEMTE's </span><span class="text-xs font-light">Fades & Shaves</span>
      </a>
      <button
        id="menu-close"
        aria-label="Close menu"
        autofocus
        class="flex-shrink-0 p-2 text-xl leading-none"
      >
        ✕
      </button>
    </div>

    <nav class="mt-8" aria-label="Site navigation">
      <ul
        class="flex flex-col gap-4 text-base font-semibold tracking-widest uppercase"
      >
        <li><a href="#home">Home</a></li>
        <li><a href="#about-me">About</a></li>
        <li><a href="#portfolio">Portfolio</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#location">Location</a></li>
      </ul>
    </nav>
    <a
      href={bookingUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-gold mt-6 inline-block px-6 py-3 whitespace-nowrap"
    >
      Book Appointment
    </a>

    <div
      class="absolute right-8 bottom-8 left-8 flex flex-col items-center gap-4"
    >
      <div class="flex flex-wrap justify-center gap-4">
        <SocialIcons size={20} />
      </div>
      <p class="text-xs font-light">&copy; 2026 TEMTE's Fades & Shaves</p>
    </div>
  </dialog>
</header>

<style>
  .nav-link {
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-gold);
  }

  /* Drawer — 75% width mobile drawer */
  #nav-drawer {
    position: fixed;
    inset: 0 auto 0 0;
    width: 75%;
    max-width: 75%;
    box-sizing: border-box;
    height: 100svh;
    max-height: 100svh;
    overflow-y: auto;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav-drawer svg {
    width: 1.25rem;
    height: 1.25rem;
    min-width: 1.25rem;
  }
  #nav-drawer a {
    min-width: 0;
  }
  #nav-drawer.is-open {
    transform: translateX(0);
  }

  /* Stagger nav items in on open */
  #nav-drawer nav li {
    opacity: 0;
    transform: translateX(10px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  #nav-drawer.is-open nav li { opacity: 1; transform: translateX(0); }
  #nav-drawer.is-open nav li:nth-child(1) { transition-delay: 0.1s; }
  #nav-drawer.is-open nav li:nth-child(2) { transition-delay: 0.16s; }
  #nav-drawer.is-open nav li:nth-child(3) { transition-delay: 0.22s; }
  #nav-drawer.is-open nav li:nth-child(4) { transition-delay: 0.28s; }
  #nav-drawer.is-open nav li:nth-child(5) { transition-delay: 0.34s; }
</style>

<script>
  const navDrawer = document.getElementById('nav-drawer') as HTMLDialogElement
  const menuOpenBtn = document.getElementById('menu-open') as HTMLButtonElement
  const menuCloseBtn = document.getElementById('menu-close') as HTMLButtonElement

  function openDrawer() {
    navDrawer.showModal()
    menuOpenBtn.setAttribute('aria-expanded', 'true')
    // Double rAF: first frame makes the dialog visible, second starts the transition
    requestAnimationFrame(() => requestAnimationFrame(() => {
      navDrawer.classList.add('is-open')
    }))
  }

  function closeDrawer() {
    navDrawer.classList.remove('is-open')
    navDrawer.addEventListener('transitionend', () => navDrawer.close(), { once: true })
  }

  menuOpenBtn.addEventListener('click', openDrawer)
  menuCloseBtn.addEventListener('click', closeDrawer)

  navDrawer.addEventListener('close', () => {
    menuOpenBtn.setAttribute('aria-expanded', 'false')
  })

  // Close on backdrop tap
  navDrawer.addEventListener('click', (event) => {
    const rect = navDrawer.getBoundingClientRect()
    if (
      event.clientX < rect.left ||
      event.clientX > rect.right ||
      event.clientY < rect.top ||
      event.clientY > rect.bottom
    ) {
      closeDrawer()
    }
  })

  // Close when a nav link inside the drawer is tapped
  navDrawer.querySelectorAll('nav a').forEach(link => {
    link.addEventListener('click', closeDrawer)
  })
</script>

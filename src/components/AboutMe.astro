---
import { Image } from 'astro:assets'
import temteImg from '../images/temte-cropped.jpeg'
---

<section id="about-me" class="scroll-mt-16 pt-16 pb-16 relative overflow-hidden min-h-screen flex flex-col justify-center">
  <div data-reveal data-reveal-early class="mb-8 px-4 text-center">
    <h2 class="section-title">About Me</h2>
    <div class="section-divider"></div>
  </div>
  <div data-reveal data-reveal-early data-reveal-delay="80" class="mx-6 mt-8 mb-2 flex flex-col lg:flex-row lg:mx-auto lg:max-w-5xl lg:w-full lg:my-12">
    <div class="lg:basis-[45%] lg:shrink-0 lg:self-center">
      <Image
        src={temteImg}
        alt="Temte"
        width={800}
        quality={85}
        class="h-full min-h-72 w-full object-cover object-top lg:min-h-0 lg:max-h-130 lg:[box-shadow:4px_8px_24px_0px_rgba(0,0,0,0.25)]"
      />
    </div>
    <div
      class="flex flex-col items-center justify-center gap-3 px-4 pt-4 pb-2 text-left lg:flex-1 lg:items-start lg:gap-6 lg:px-14 lg:py-0"
    >
      <div class="lg:border-l-2 lg:border-gold lg:pl-5 self-stretch">
        <h2 class="text-4xl font-bold [word-spacing:-0.01em] text-center lg:text-5xl lg:text-left">
          Hi, I'm <span class="text-gold">Temte</span>
        </h2>
      </div>
      <p class="max-w-[72ch] leading-tight tracking-tight text-base lg:text-lg lg:max-w-none">
        I specialize in fades, beard work, and detailed design cuts. I also
        offer hot lather straight razor services, along with hot wax and
        skincare treatments to elevate your experience.
        <br /><br />
        My goal is simple: to give you a great conversation and a meticulously detailed
        haircut that brings a new level of confidence. A cut that looks sharp today
        — and stays easy to style and manage for 2–4 weeks after.
      </p>
    </div>
  </div>

  <!-- stats bar -->
  <div data-reveal data-reveal-early data-reveal-delay="140" class="mx-auto max-w-5xl w-full px-6 lg:px-0 mt-2">
    <div class="grid grid-cols-1 gap-3 text-center lg:grid-cols-3 lg:gap-4">
      <div class="border border-black/10 bg-white px-3 py-3 shadow-sm lg:px-4 lg:py-5">
        <div class="text-2xl font-bold text-gold lg:text-3xl">10+</div>
        <div class="mt-1 text-sm uppercase tracking-widest text-black/50">Years Experience</div>
      </div>
      <div class="border border-black/10 bg-white px-3 py-3 shadow-sm lg:px-4 lg:py-5">
        <div class="text-2xl font-bold text-gold lg:text-3xl">1K+</div>
        <div class="mt-1 text-sm uppercase tracking-widest text-black/50">Clients Served</div>
      </div>
      <div class="border border-black/10 bg-white px-3 py-3 shadow-sm lg:px-4 lg:py-5">
        <div class="text-2xl font-bold text-gold lg:text-3xl">5.0★</div>
        <div class="mt-1 text-sm uppercase tracking-widest text-black/50">89 Booksy Reviews</div>
      </div>
    </div>
  </div>

  <!-- testimonials -->
  <div data-reveal data-reveal-early data-reveal-delay="180" class="mt-10 pb-4 lg:mx-auto lg:max-w-5xl lg:w-full lg:px-0">
    <p class="mb-3 ml-6 text-sm uppercase tracking-widest text-black/40 whitespace-nowrap lg:hidden">What clients say</p>
    <div class="relative">
      <div id="reviews-carousel" class="mx-6 flex snap-x snap-mandatory overflow-x-auto gap-3 pb-2 [scrollbar-width:thin] [scrollbar-color:#c4a84e_transparent] lg:mx-0 lg:grid lg:grid-cols-3 lg:overflow-visible lg:pb-0 lg:gap-4">
        <div class="border border-black/10 flex flex-col p-5 min-w-[85%] shrink-0 min-h-48 snap-start lg:min-w-0 lg:min-h-0 lg:p-6">
          <div class="mb-1 font-serif text-5xl leading-none text-gold/50">"</div>
          <p class="text-base italic leading-relaxed text-black/70 max-w-[32ch] lg:max-w-none">That was the best experience ever! Temte snapped with my son's hair. I am obsessed with how great it looks — the atmosphere is a VIBE!</p>
          <div class="mt-auto pt-4 text-base uppercase tracking-widest text-gold">— Morgan</div>
        </div>
        <div class="border border-black/10 flex flex-col p-5 min-w-[85%] shrink-0 min-h-48 snap-start lg:min-w-0 lg:min-h-0 lg:p-6">
          <div class="mb-1 font-serif text-5xl leading-none text-gold/50">"</div>
          <p class="text-base italic leading-relaxed text-black/70 max-w-[32ch] lg:max-w-none">The most relaxing haircut I've had in a long time.</p>
          <div class="mt-auto pt-4 text-base uppercase tracking-widest text-gold">— Tegan</div>
        </div>
        <div class="border border-black/10 flex flex-col p-5 min-w-[85%] shrink-0 min-h-48 snap-start lg:min-w-0 lg:min-h-0 lg:p-6">
          <div class="mb-1 font-serif text-5xl leading-none text-gold/50">"</div>
          <p class="text-base italic leading-relaxed text-black/70 max-w-[32ch] lg:max-w-none">Temte is always spot on! She makes my son look like a million bucks and that makes him happy.</p>
          <div class="mt-auto pt-4 text-base uppercase tracking-widest text-gold">— Jessica</div>
        </div>
      </div>
    </div>
    <!-- dot indicators -->
    <div class="flex justify-center gap-2 mt-3 lg:hidden">
      <div class="review-dot h-1.5 w-4 rounded-full bg-gold transition-all duration-300"></div>
      <div class="review-dot h-1.5 w-1.5 rounded-full bg-black/20 transition-all duration-300"></div>
      <div class="review-dot h-1.5 w-1.5 rounded-full bg-black/20 transition-all duration-300"></div>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('reviews-carousel') as HTMLElement | null;
  const dots = Array.from(document.querySelectorAll('.review-dot'));

  if (carousel && dots.length) {
    carousel.addEventListener('scroll', () => {
      const max = carousel.scrollWidth - carousel.clientWidth;
      const idx = max > 0 ? Math.round((carousel.scrollLeft / max) * (dots.length - 1)) : 0;
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-gold', i === idx);
        dot.classList.toggle('w-4', i === idx);
        dot.classList.toggle('bg-black/20', i !== idx);
        dot.classList.toggle('w-1.5', i !== idx);
      });
    }, { passive: true });
  }
</script>

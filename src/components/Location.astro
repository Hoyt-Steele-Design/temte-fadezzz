---
import locationImg from '../images/location.jpg'
---

<section id="location" class="flex scroll-mt-16 flex-col pt-16 pb-8 px-4">
  <div data-reveal class="max-w-3xl mx-auto w-full">
    <a
      href="https://maps.apple.com/?address=8030+Glen+Ln,+Suite+18,+Eden+Prairie,+55344"
      target="_blank"
      rel="noopener noreferrer"
      class="group relative mb-4 block cursor-pointer"
    >
      <img
        src={locationImg.src}
        alt="Temte's Fades & Shaves location"
        class="h-64 w-full object-cover object-[center_25%]"
      />
      <div class="absolute inset-0 bg-linear-to-t from-black/90 to-transparent"></div>
      <div class="absolute inset-0 bg-white/0 transition-all duration-300 group-hover:bg-white/10"></div>
      <div class="absolute inset-0 flex flex-col items-start justify-end p-4 text-white">
        <h2 class="font-garamond text-4xl font-bold">Location</h2>
        <div class="flex w-full items-end justify-between">
          <p class="mt-1 text-sm">8030 Glen Ln, Suite 18, Eden Prairie, 55344</p>
          <span class="ml-3 shrink-0 rounded-full border border-white/40 px-2.5 py-1 text-xs font-semibold tracking-wide text-white/90">
            Open in Maps ↗
          </span>
        </div>
      </div>
    </a>

  </div>
</section>

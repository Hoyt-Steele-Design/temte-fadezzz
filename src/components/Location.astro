---
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
const reader = createReader(process.cwd(), keystaticConfig)
const location = await reader.singletons.location.read()
const locationImage = location?.locationImage?.trim()
const locationImageSrc = locationImage
  ? locationImage.startsWith('/')
    ? locationImage
    : `/images/location/${locationImage}`
  : '/images/location/location.jpg'
---

<section id="location" class="flex scroll-mt-16 flex-col px-4 pt-16 pb-8">
  <div data-reveal class="mx-auto w-full max-w-3xl">
    <a
      href={location?.mapUrl ?? '#'}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative mb-4 block cursor-pointer"
    >
      <img
        src={locationImageSrc}
        alt="Temte's Fades & Shaves location"
        width="768"
        loading="lazy"
        class="h-64 w-full object-cover object-[center_25%]"
      />
      <div class="absolute inset-0 bg-linear-to-t from-black/90 to-transparent">
      </div>
      <div
        class="absolute inset-0 bg-white/0 transition-all duration-300 group-hover:bg-white/10"
      >
      </div>
      <div
        class="absolute inset-0 flex flex-col items-start justify-end p-4 text-white"
      >
        <h2 class="font-garamond text-4xl font-bold">Location</h2>
        <div class="flex w-full items-end justify-between">
          <p class="mt-1 text-base">
            {location?.address}
          </p>
          <span
            class="ml-3 shrink-0 rounded-full border border-white/40 px-2.5 py-1 text-sm font-semibold tracking-wide text-white/90"
          >
            Open in Maps ↗
          </span>
        </div>
      </div>
    </a>

    <!-- Hours -->
    <div class="border border-black/10 px-5 py-4">
      <h3
        class="font-inter mb-3 text-xs font-semibold tracking-widest text-neutral-500 uppercase"
      >
        Hours
      </h3>
      <ul class="flex flex-col gap-3">
        {(location?.hours ?? []).map((h) => (
          <li class="flex items-start justify-between">
            <span class="font-medium">{h.day}</span>
            {h.isClosed ? (
              <span class="text-neutral-400">Closed</span>
            ) : (
              <span class="flex flex-col items-end text-neutral-400">
                {h.slots.map((slot) => (
                  <span>{slot}</span>
                ))}
              </span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

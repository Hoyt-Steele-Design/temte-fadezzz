---
import locationImg from '../images/location.jpg'
---

<section id="location" class="location flex scroll-mt-16 flex-col">
  <div class="relative mb-4">
    <img
      src={locationImg.src}
      alt="Temte's Fades & Shaves location"
      class="h-64 w-full object-cover object-[center_25%]"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent">
    </div>
    <div
      class="absolute inset-0 flex flex-col items-start justify-end p-4 text-white"
    >
      <h2 class="font-garamond text-4xl font-bold">Location</h2>
      <p class="mt-1 text-sm">8030 Glen Ln, Suite 18, Eden Prairie, 55344</p>
    </div>
  </div>

  <div class="flex flex-col items-center gap-3 px-8">
    <a
      href="https://booksy.com/en-us/936262_temtes-fades-shaves_barber-shop_24080_eden-prairie#ba_s=seo"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-gold w-64 px-6 py-3"
    >
      Book Appointment
    </a>
    <a href="#portfolio" class="btn btn-ghost mb-8 w-64 px-6 py-3">
      View Portfolio
    </a>
  </div>
</section>

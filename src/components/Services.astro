---
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
const reader = createReader(process.cwd(), keystaticConfig)
const services = await reader.singletons.services.read()
const serviceGroups = services?.serviceGroups ?? []
const disclaimer = services?.disclaimer ?? ''
const settings = await reader.singletons.settings.read()
const bookingUrl = settings?.bookingUrl ?? ''
---

<section id="services" class="scroll-mt-16 px-4 pt-16 pb-8">
  <div data-reveal class="mb-10 text-center">
    <h2 class="section-title">Services</h2>
    <div class="section-divider"></div>
    <p
      class="font-inter mt-4 text-xs font-semibold tracking-widest text-neutral-500 uppercase"
    >
      {disclaimer}
    </p>

  </div>

  <div class="mx-auto flex max-w-3xl flex-col gap-10 lg:flex-row lg:gap-6">
    {
      serviceGroups.map((group, i) => (
        <div data-reveal data-reveal-delay={80 + i * 80} class="flex-1">
          <h3 class="font-inter text-gold mb-4 border-b border-neutral-200 pb-2 text-xs font-semibold tracking-widest uppercase">
            {group.category}
          </h3>
          <ul class="flex flex-col gap-5">
            {group.services.map((service) => (
              <li class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-inter text-sm font-semibold">{service.name}</p>
                  <p class="font-inter text-sm text-neutral-500">
                    {service.description}
                  </p>
                  {service.duration && service.duration !== '—' && (
                    <p class="font-inter mt-0.5 text-xs text-neutral-400">
                      {service.duration}
                    </p>
                  )}
                </div>
                <data
                  value={service.price}
                  class="font-inter text-gold text-sm font-semibold whitespace-nowrap"
                >
                  {service.price}
                </data>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div data-reveal class="mx-auto flex max-w-3xl w-full flex-col gap-3 mt-10 px-4">
    <a
      href={bookingUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-gold w-full px-6 py-4"
    >
      — Book Appointment —
    </a>
    <a href="#portfolio" class="btn btn-ghost w-full px-6 py-4">
      — View Portfolio —
    </a>
  </div>
</section>

---
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)
const portfolio = await reader.singletons.portfolio.read()
const images = (portfolio?.images ?? []).map((img) => ({
  image: img.image ? `/images/portfolio/${img.image}` : '',
  alt: img.alt,
}))

const DURATION = 5
const TOTAL = images.length * DURATION
---

<section id="portfolio" class="scroll-mt-16 pt-16 pb-16">
  <div data-reveal class="mb-8 px-4 text-center">
    <h2 class="section-title">Portfolio</h2>
    <div class="section-divider"></div>
  </div>

  <!-- Mobile: crossfade slideshow -->
  <div data-reveal data-reveal-delay="100" class="portfolio-stage lg:hidden">
    {images.map((img, i) => (
      <img
        src={img.image}
        alt={img.alt}
        width="800"
        height="1067"
        loading="lazy"
        class="portfolio-slide"
        style={`animation-delay: ${i * DURATION}s; animation-duration: ${TOTAL}s`}
      />
    ))}
  </div>

  <!-- Desktop: 3×2 image grid -->
  <div data-reveal data-reveal-delay="100" class="portfolio-grid hidden lg:grid">
    {images.map((img) => (
      <div class="portfolio-grid-item">
        <img
          src={img.image}
          alt={img.alt}
          width="600"
          height="800"
          loading="lazy"
          class="portfolio-grid-img"
        />
      </div>
    ))}
  </div>
</section>

<style>
  .portfolio-stage {
    position: relative;
    width: calc(100% - 3rem);
    max-width: 22rem;
    margin: 0 auto;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .portfolio-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    opacity: 0;
    animation: crossfade linear infinite backwards;
  }

  /* Per-image duration: 5s (1s in, 3s hold, 1s out), total cycle: 30s
     Keyframe percentages are relative to total cycle (30s):
       0%      = 0s   → invisible
       3.33%   = 1s   → fully visible (fade-in complete)
       13.33%  = 4s   → still fully visible (hold ends)
       16.67%  = 5s   → invisible again (fade-out complete)
       100%    = 30s  → still invisible (waiting) */
  @keyframes crossfade {
    0%      { opacity: 0; }
    3.33%   { opacity: 1; }
    13.33%  { opacity: 1; }
    16.67%  { opacity: 0; }
    100%    { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-slide {
      animation: none;
      opacity: 1;
    }
    .portfolio-slide:not(:first-child) {
      display: none;
    }
  }

  /* Desktop grid */
  .portfolio-grid {
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 0.5rem;
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .portfolio-grid-item {
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .portfolio-grid-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .portfolio-grid-item:hover .portfolio-grid-img {
    transform: scale(1.04);
  }
</style>

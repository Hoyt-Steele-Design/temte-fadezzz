---
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)
const portfolio = await reader.singletons.portfolio.read()
type PhotoSlot = { image: string | null; alt: string }
const images = (['photo1','photo2','photo3','photo4','photo5','photo6'] as const)
  .map(key => portfolio?.[key] as PhotoSlot | undefined)
  .filter((p): p is PhotoSlot & { image: string } => typeof p?.image === 'string' && p.image.length > 0)
  .map(p => ({ image: `/images/portfolio/${p.image}`, alt: p.alt }))
---

<section id="portfolio" class="scroll-mt-16 pt-16 pb-16">
  <div data-reveal class="mb-8 px-4 text-center">
    <h2 class="section-title">Portfolio</h2>
    <div class="section-divider"></div>
  </div>

  <!-- Mobile: auto-advancing carousel with swipe -->
  <div data-reveal data-reveal-delay="100" class="lg:hidden">
    <div id="portfolio-wrapper" class="portfolio-wrapper">
      <div id="portfolio-track" class="portfolio-track">
        {images.map((img) => (
          <div class="portfolio-slide">
            <img
              src={img.image}
              alt={img.alt}
              width="800"
              height="1067"
              loading="lazy"
              class="w-full h-full object-cover object-top"
            />
          </div>
        ))}
      </div>
    </div>
    <div class="flex justify-center gap-2 mt-3">
      {images.map((_, i) => (
        <div class={`portfolio-dot h-1.5 rounded-full transition-all duration-300 ${i === 0 ? 'w-4 bg-gold' : 'w-1.5 bg-black/20'}`}></div>
      ))}
    </div>
  </div>

  <!-- Desktop: 3×2 image grid -->
  <div data-reveal data-reveal-delay="100" class="portfolio-grid hidden lg:grid">
    {images.map((img) => (
      <div class="portfolio-grid-item">
        <img
          src={img.image}
          alt={img.alt}
          width="600"
          height="800"
          loading="lazy"
          class="portfolio-grid-img"
        />
      </div>
    ))}
  </div>
</section>

<style>
  .portfolio-wrapper {
    width: calc(100% - 3rem);
    max-width: 22rem;
    margin: 0 auto;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .portfolio-track {
    display: flex;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .portfolio-slide {
    min-width: 100%;
    height: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-track {
      transition: none;
    }
  }

  /* Desktop grid */
  .portfolio-grid {
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 0.5rem;
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .portfolio-grid-item {
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .portfolio-grid-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .portfolio-grid-item:hover .portfolio-grid-img {
    transform: scale(1.04);
  }
</style>

<script>
  const wrapper = document.getElementById('portfolio-wrapper') as HTMLElement | null;
  const track = document.getElementById('portfolio-track') as HTMLElement | null;
  const dots = Array.from(document.querySelectorAll('.portfolio-dot'));
  const total = dots.length;

  if (!wrapper || !track || total === 0) {
    // do nothing
  } else {
    const t = track;
    let current = 0;
    let autoTimer: number;
    let resumeTimer: number;
    let touchStartX = 0;

    function goTo(idx: number) {
      current = ((idx % total) + total) % total;
      t.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-gold', i === current);
        dot.classList.toggle('w-4', i === current);
        dot.classList.toggle('bg-black/20', i !== current);
        dot.classList.toggle('w-1.5', i !== current);
      });
    }

    function startAuto() {
      clearInterval(autoTimer);
      autoTimer = window.setInterval(() => goTo(current + 1), 5000);
    }

    function pauseAuto() {
      clearInterval(autoTimer);
      clearTimeout(resumeTimer);
      resumeTimer = window.setTimeout(startAuto, 8000);
    }

    startAuto();

    wrapper.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      pauseAuto();
    }, { passive: true });

    wrapper.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    }, { passive: true });

    let wheelAccum = 0;
    let wheelLocked = false;
    let wheelAccumTimer: number;

    wrapper.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) return;
      e.preventDefault();

      if (wheelLocked) return;

      wheelAccum += e.deltaX;

      clearTimeout(wheelAccumTimer);
      wheelAccumTimer = window.setTimeout(() => { wheelAccum = 0; }, 150);

      if (Math.abs(wheelAccum) > 40) {
        pauseAuto();
        goTo(wheelAccum > 0 ? current + 1 : current - 1);
        wheelAccum = 0;
        wheelLocked = true;
        window.setTimeout(() => { wheelLocked = false; }, 700);
      }
    }, { passive: false });
  }
</script>
